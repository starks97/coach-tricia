---
interface Props {
	title: string
	description: string
	image: string
	subtitle: string
}

const { title, description, subtitle } = Astro.props as Props

import HeroWrapper from "../HeroWrapper.astro"

const heroImage =
	"https://res.cloudinary.com/dyrtdhsl0/image/upload/v1749081866/about_me_fapa4j.webp"
---

<HeroWrapper img={heroImage} class="tablet:flex-row-reverse">
	<h1
		class="font-blackstone tablet:text-left tablet:text-size-8 laptop:text-size-9 text-light-rose text-center text-[3rem] font-light opacity-0"
		:class="intersect ? 'animate-fade-up animate-ease-in-out  animate-delay-200 ' : 'opacity-0'"
	>
		{title.toLowerCase()}
	</h1>
	<p
		class="font-prata laptop:text-left tablet:text-size-5 laptop:text-size-6 text-justify text-[2rem] opacity-0"
		:class="intersect ? 'animate-fade-left animate-ease-in-out  animate-delay-300 ' : 'opacity-0'"
	>
		<em class="font-italic">{subtitle}</em>
	</p>
	<p
		class="font-tajawal tablet:text-left text-size-4 text-justify opacity-0"
		:class="intersect ? 'animate-fade-left animate-ease-in-out  animate-delay-300 ' : 'opacity-0'"
	>
		{description}
	</p>
</HeroWrapper>
