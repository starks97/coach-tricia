---
import CalendlyWidget from "../CalendlyWidget.astro"

interface Props {
	title: string
	img: string
	description: string
	subtitle: string
}

const { title, img, description, subtitle } = Astro.props as Props
---

<section
	class="section mx-auto w-full space-y-10 bg-[#fbf4f2] p-10"
	x-data="{ intersect: false }"
	x-intersect:enter="intersect = true"
	x-intersect:leave="intersect = false"
>
	<div
		class="h-auto w-full opacity-0"
		:class="intersect ? 'animate-fade-up animate-ease-in  animate-delay-200 ' : 'opacity-0'"
	>
		<h2
			class="font-prata tablet:text-size-7 laptop:text-[3rem] text-size-5 w-full text-center leading-14 font-light"
		>
			Free Consultation
		</h2>
	</div>
	<div
		class="mx-auto grid h-auto grid-cols-1 justify-items-center opacity-0"
		:class="intersect ? 'animate-fade-left animate-ease-in-out  animate-delay-400 ' : 'opacity-0'"
	>
		<div
			class="tablet:flex-row tablet:space-y-0 flex scale-100 flex-col items-center justify-center space-y-10"
		>
			<div
				class="tablet:max-w-sm tablet:translate-x-5 tablet:p-5 laptop:max-w-lg laptop:p-11 bg-light-cream z-40 mx-auto flex w-full translate-x-0 flex-col space-y-3 p-10"
			>
				<h3
					class="font-prata text-size-5 tablet:text-size-6 laptop:text-size-7 tablet:text-left text-center text-3xl"
				>
					{title}
				</h3>
				<p class="font-tajawal text-light-rose tablet:text-size-5 laptop:text-3xl text-xl">
					{subtitle}
				</p>
				<p class="font-tajawal tablet:text-lg text-size-3">
					{description}
				</p>

				<div class="tablet:justify-center flex w-full justify-center gap-5">
					<CalendlyWidget btnLabel="Book a Free Call" />
				</div>
			</div>

			<img
				src={img}
				alt="Tricia Rago coaching consultation"
				class="tablet:h-100 tablet:w-100 tablet:-translate-x-5 laptop:h-125 laptop:w-125 h-64 w-full translate-x-0 object-cover"
			/>
		</div>
	</div>
</section>
