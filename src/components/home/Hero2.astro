---
import Testimonials from "./Testimonial.astro"


---
<div class="grid grid-cols-1 md:grid-cols-2 gap-5 bg-hero_bg mx-auto items-center min-h-screen px-16">
    <div class="flex flex-col gap-10 items-center md:items-start w-full max-w-lg mx-auto">
           <h2 class="font-prata text-xl md:text-4xl lg:text-5xl text-center md:text-left leading-tight">
               You are talented and driven. Ready to share your passion with the world but not sure how best to do it.
           </h2>

           <h3 class="font-prata text-lg md:text-2xl lg:text-3xl text-center md:text-left text-hero_color">
               Let me guess, right now you...
           </h3>

           <li class="flex items-start">
                   <!-- SVG Icon -->
                   <svg
                       xmlns="http://www.w3.org/2000/svg"
                       viewBox="0 0 512 512"
                       class="w-10 h-10 text-hero_color flex-shrink-0 mt-1"
                       fill="currentColor"
                       aria-hidden="true"
                   >
                       <path d="M405 136.798L375.202 107 256 226.202 136.798 107 107 136.798 226.202 256 107 375.202 136.798 405 256 285.798 375.202 405 405 375.202 285.798 256"></path>
                   </svg>

                   <!-- List Item Text -->
                   <span class="ml-4 text-lg md:text-xl lg:text-2xl text-gray-800">
                       Are overwhelmed by the idea of creating a website that truly reflects your brand and message.
                   </span>
            </li>
    </div>
    <div class="flex justify-center">
        <!-- Assuming Testimonials is a React component or similar -->
        <Testimonials />
    </div>
</div>
