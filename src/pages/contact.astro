---
import Layout from "../layouts/Layout.astro"

import ContactLayout from "../components/contact/ContactLayout.astro"
import Hero from "../components/contact/Hero.astro"

import { type ContactPageZodSchemaType, ContactPageSchema } from "@lib/db/models/contact.ts"
import getPage from "@lib/db/queries/getPage.ts"
import getSEO from "@lib/db/queries/getSEO.ts"

const data = await getPage<ContactPageZodSchemaType>(
	"contact_page_id",
	"contact",
	ContactPageSchema
)

const seoData = await getSEO("seo_id", "seo", "contact")
const heroData = data.hero

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=3600")
---

<Layout title={seoData!.title} description={seoData!.description} image={heroData.image}>
	<script
		slot="jsonld"
		type="application/ld+json"
		set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ContactPage",
			"name": "Book a Free Discovery Call | Tricia Rago Coaching",
			"url": "https://www.coachtriciarago.com/contact",
			"description":
				"Book a free discovery call with Tricia Rago and take your first step toward healing after divorce or heartbreak.",
			"mainEntity": {
				"@type": "Person",
				"name": "Tricia Rago",
				"url": "https://www.coachtriciarago.com",
				"contactPoint": {
					"@type": "ContactPoint",
					"contactType": "customer support",
					"availableLanguage": "English",
					"url": "https://www.coachtriciarago.com/contact",
				},
			},
		})}
		is:inline
	/>
	<Hero
		title={heroData.title}
		description={heroData.description}
		image={heroData.image}
		subtitle={heroData.subtitle}
	/>
	<ContactLayout />
</Layout>
